# Configurações do Ambiente de Staging (Teste de Migração)
# Copie este arquivo para .env.staging e preencha com as credenciais do seu projeto Supabase de Teste

# ----------------------------
# Supabase - Conexão
# ----------------------------
# URL do projeto Supabase de Staging
VITE_SUPABASE_URL=https://seu-projeto-staging.supabase.co

# Chave Anônima (public) - Usada pelos testes de integração e frontend
VITE_SUPABASE_ANON_KEY=sua-chave-anon-staging

# Chave de Serviço (secret) - Usada APENAS pelos scripts de migração (scripts/supabase-migrate.ts)
# NÃO use esta chave no frontend
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-staging

# Para compatibilidade com scripts que usam nomes diferentes
SUPABASE_URL=https://seu-projeto-staging.supabase.co
SUPABASE_ANON_KEY=sua-chave-anon-staging
