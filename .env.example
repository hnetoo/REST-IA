# ============================
# Variáveis de Ambiente - Exemplo
# Copie para .env.local para desenvolvimento local
# ============================

# ----------------------------
# Supabase - Backend as a Service
# ----------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ----------------------------
# Prisma Database Connection (OBRIGATÓRIO)
# ----------------------------
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/postgres"

# ----------------------------
# Google Gemini AI (Opcional)
# ----------------------------
VITE_GEMINI_API_KEY=your_gemini_api_key

# ----------------------------
# Configurações da Aplicação
# ----------------------------
NODE_ENV=development
VITE_APP_URL=http://localhost:3000

# ----------------------------
# Features Flags
# ----------------------------
VITE_ENABLE_PUBLIC_MENU=true
VITE_ENABLE_CUSTOMER_DISPLAY=true
VITE_ENABLE_AUTO_SYNC=true

# ----------------------------
# Analytics e Monitoramento (Opcional)
# ----------------------------
VITE_GA_TRACKING_ID=
VITE_SENTRY_DSN=

# ----------------------------
# APIs Externas (Opcional)
# ----------------------------
VITE_PAYMENT_API_URL=
VITE_DELIVERY_API_URL=

# ----------------------------
# Nota Prisma/Supabase:
# ----------------------------
# - DATABASE_URL: Connection string principal para Prisma
# - DIRECT_URL: Connection string para modo transação
# - Pegue as credenciais no Supabase > Database > Connection string
# - Use pgbouncer=true para pooling de conexões
# - connection_limit=1 para ambientes serverless
