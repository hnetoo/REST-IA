{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|api/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "framework": "vite"
}
