{
  "productName": "Tasca do Vereda POS",
  "version": "1.0.6",
  "identifier": "ao.vereda.gestao.restaurante",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tasca do Vereda POS v1.0.6",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/Square310x310Logo.png",
      "icons/Square150x150Logo.png",
      "icons/Square142x142Logo.png",
      "icons/Square107x107Logo.png",
      "icons/Square89x89Logo.png",
      "icons/Square71x71Logo.png",
      "icons/Square44x44Logo.png",
      "icons/Square30x30Logo.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Vereda Systems Angola",
    "windows": {
      "wix": {
        "language": "pt-PT"
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:tasca_vereda.db"]
    },
    "notification": {
      "all": true
    }
  }
}